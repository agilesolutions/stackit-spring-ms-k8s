{
  "id": "overheid",
  "realm": "overheid",
  "enabled": true,
  "displayName": "Overheid Test Realm",

  "sslRequired": "external",
  "registrationAllowed": false,
  "loginWithEmailAllowed": false,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": false,

  "roles": {
    "realm": [
      {
        "name": "zaken.read"
      },
      {
        "name": "zaken.write"
      },
      {
        "name": "vergunning.read"
      },
      {
        "name": "vergunning.write"
      },
      {
        "name": "offline_access"
      },
      {
        "name": "uma_authorization"
      }
    ]
  },

  "clients": [
    {
      "clientId": "vergunning-service",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "test-secret",
      "serviceAccountsEnabled": true,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "implicitFlowEnabled": false,
      "authorizationServicesEnabled": false,
      "fullScopeAllowed": true,
      "defaultClientScopes": [
        "profile",
        "email",
        "roles"
      ]
    },
    {
      "clientId": "zaken-service",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "test-secret",
      "serviceAccountsEnabled": true,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "implicitFlowEnabled": false,
      "authorizationServicesEnabled": false,
      "fullScopeAllowed": true,
      "defaultClientScopes": [
        "profile",
        "email",
        "roles"
      ]
    },
    {
      "clientId": "burger-service",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "test-secret",
      "serviceAccountsEnabled": true,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "implicitFlowEnabled": false,
      "authorizationServicesEnabled": false,
      "fullScopeAllowed": true,
      "defaultClientScopes": [
        "profile",
        "email",
        "roles"
      ]
    }
  ],

  "users": [
    {
      "username": "beheerder",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Platform",
      "lastName": "Beheerder",
      "credentials": [
        {
          "type": "password",
          "value": "secret",
          "temporary": false
        }
      ],
      "realmRoles": [
        "zaken.read",
        "zaken.write",
        "vergunning.read",
        "vergunning.write"
      ]
    }
  ]
}